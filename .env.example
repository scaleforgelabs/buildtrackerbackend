# Database Configuration
DB_NAME=buildtracker
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration (install Redis locally)
REDIS_URL=redis://127.0.0.1:6379/1

# Celery Configuration
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# Set to True for local dev without a Celery worker. MUST be False in production.
CELERY_TASK_ALWAYS_EAGER=True

# Django Secret Key
SECRET_KEY=django-insecure-s295&ts4sox(+j3l%s2hnsq3x(x9xmhssp+d1+5402@79^j+a8

# Google OAuth
GOOGLE_OAUTH2_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH2_CLIENT_SECRET=your_google_client_secret

# Apple OAuth  
APPLE_CLIENT_ID=your_apple_client_id
APPLE_KEY_ID=your_apple_key_id
APPLE_TEAM_ID=your_apple_team_id

# AWS S3 Storage
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_STORAGE_BUCKET_NAME=your_bucket_name
AWS_S3_REGION_NAME=us-east-1

# WhatsApp Business Cloud API (Meta)
# How to get these — see setup guide below:
#   1. Go to https://developers.facebook.com and create an app (type: Business)
#   2. Add "WhatsApp" product to your app
#   3. Go to WhatsApp → API Setup to find your Phone Number ID and temporary token
#   4. For production, generate a permanent System User token in Business Settings
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_VERSION=v19.0
# Template names — must match exactly what you created in Meta Business Manager
WHATSAPP_TEMPLATE_TASK=buildtracker_task_notification
WHATSAPP_TEMPLATE_PLAIN=buildtracker_notification